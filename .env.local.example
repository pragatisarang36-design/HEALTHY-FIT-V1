# Put your Groq API key here for local AI features.
VITE_GROQ_API_KEY=your_groq_key_here

# Optional. Defaults to the project root when omitted.
DATA_ROOT=.

# Required for deployed web/mobile builds. Set this to the public HTTPS URL of
# healthy-fit-backend; localhost only works for local browser development and
# resolves to the device itself on phones or other machines.
VITE_BACKEND_API_URL=https://your-backend.example.com
